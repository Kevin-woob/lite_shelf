RewriteEngine On

# Dynamically determine RewriteBase (works in any subdirectory)
RewriteCond %{REQUEST_URI} ^(.*)/index\.php$
RewriteRule ^.*$ - [E=REWRITE_BASE:%1]

# Route admin API calls to admin/api.php
RewriteRule ^admin/api(.*)$ admin/api.php [L]

# Route all other non-file/directory requests to index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [L]
